go-module_set_globals

SRC_URI="
https://github.com/VictoriaMetrics/${PN}/archive/v${PV}.tar.gz -> ${P}.tar.gz
${EGO_SUM_SRC_URI}
"

DEPEND="acct-user/vmetrics"
RDEPEND="${DEPEND}"

src_compile() {
	use server && emake victoria-metrics
	use vmagent && emake vmagent
	use vmalert && emake vmalert
}

src_install() {
	if use server; then
		newbin bin/victoria-metrics victoriametrics

		newinitd "${FILESDIR}/victoriametrics.initd" victoriametrics
		newconfd "${FILESDIR}/victoriametrics.confd" victoriametrics

		diropts -o vmetrics -g vmetrics
		keepdir /var/lib/victoriametrics
		keepdir /var/log/victoriametrics
	fi

	if use vmalert; then
		newbin bin/vmalert vmalert

		newinitd "${FILESDIR}/vmalert.initd" vmalert
		newconfd "${FILESDIR}/vmalert.confd" vmalert
	fi

	use vmagent && newbin bin/vmagent vmagent
}
